rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // The organiser account allowed to view all registrations and mark
    // payments from the admin dashboard. IMPORTANT: replace this with the
    // email of the Firebase Auth account you created for the admin, then
    // Publish. Security depends on this — anyone else is refused list/update.
    function isAdmin() {
      return request.auth != null
             && request.auth.token.email == "REPLACE_WITH_ADMIN_EMAIL";
    }

    match /registrations/{registrationId} {

      // Anyone can CREATE a registration (this is how the public form saves data),
      // but only if it has the expected shape. totalAmount can be 0 (Free Darshana).
      allow create: if request.resource.data.keys().hasAll(
                        ['fullName', 'phone', 'email', 'address', 'participants', 'sevas',
                         'totalAmount', 'paymentMethod', 'paymentStatus', 'orderId', 'createdAt']
                      )
                    && request.resource.data.totalAmount is number
                    && request.resource.data.totalAmount >= 0
                    && request.resource.data.fullName is string
                    && request.resource.data.email is string
                    && request.resource.data.orderId == registrationId
                    && request.resource.data.paymentStatus in ['pending', 'not_required'];

      // A single registration can be read directly by its exact document ID
      // (i.e. only someone who already has the ID/QR code) — this powers the
      // entrance check-in page. The admin can also read individual docs.
      allow get: if true;

      // Only the admin can list/query the whole collection (the dashboard).
      allow list: if isAdmin();

      // Only the admin can update — and only the payment fields, so a
      // compromised admin session can't rewrite someone's personal details.
      allow update: if isAdmin()
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['paymentStatus', 'paidAt'])
                    && request.resource.data.paymentStatus in ['pending', 'paid', 'not_required'];

      allow delete: if false;
    }
  }
}
